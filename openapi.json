{
    "openapi": "3.1.0",
    "info": {
        "title": "Nutrition Label Compliance Checker",
        "description": "Upload an image of a nutrition label to extract vitamin data and evaluate compliance with health standards.",
        "version": "1.0.0"
    },
    "paths": {
        "/upload-image/": {
            "post": {
                "summary": "Upload a nutrition label image",
                "description": "Endpoint to upload an image of a nutrition label.\n\n- Accepts: image file (e.g., .jpg, .png)\n- Process:\n    1. Saves the uploaded image to a temporary file.\n    2. Extracts nutrition information using OCR (NutritionLabelExtractor).\n    3. Uses a Generative AI agent (FoodReviewerAgent) to assess whether the\n       vitamins listed comply with dietary standards.\n- Returns:\n    - Markdown-formatted compliance report (text/plain).\n    - HTTP 400 if image processing fails.\n\nArgs:\n    file (UploadFile): The uploaded image file containing the nutrition label.\n\nReturns:\n    str: Markdown text containing extracted nutrition analysis.",
                "operationId": "upload_image_upload_image__post",
                "requestBody": {
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/Body_upload_image_upload_image__post"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "text/plain": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Body_upload_image_upload_image__post": {
                "properties": {
                    "file": {
                        "type": "string",
                        "format": "binary",
                        "title": "File"
                    }
                },
                "type": "object",
                "required": [
                    "file"
                ],
                "title": "Body_upload_image_upload_image__post"
            },
            "HTTPValidationError": {
                "properties": {
                    "detail": {
                        "items": {
                            "$ref": "#/components/schemas/ValidationError"
                        },
                        "type": "array",
                        "title": "Detail"
                    }
                },
                "type": "object",
                "title": "HTTPValidationError"
            },
            "ValidationError": {
                "properties": {
                    "loc": {
                        "items": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "integer"
                                }
                            ]
                        },
                        "type": "array",
                        "title": "Location"
                    },
                    "msg": {
                        "type": "string",
                        "title": "Message"
                    },
                    "type": {
                        "type": "string",
                        "title": "Error Type"
                    }
                },
                "type": "object",
                "required": [
                    "loc",
                    "msg",
                    "type"
                ],
                "title": "ValidationError"
            }
        }
    }
}
